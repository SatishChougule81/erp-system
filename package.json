{
  "name": "erp-system",
  "version": "1.0.0",
  "description": "Complete ERP System with Basic and Medium Features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:client",
